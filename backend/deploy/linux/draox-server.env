# ================================================
# Draox Server — Environment Variables
# Place at: /etc/draox-server/draox-server.env
# ================================================

# Log level: trace, debug, info, warn, error
RUST_LOG=info,draox_server=info

# Show backtrace on panic (0=off, 1=on, full=verbose)
RUST_BACKTRACE=0

# Admin API JWT secret (REQUIRED — change this!)
DRAOX_ADMIN_JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING

# Optional: override config values via environment
# DRAOX_SERVER_HOST=0.0.0.0
# DRAOX_TCP_PORT=9000
# DRAOX_UDP_PORT=9001
# DRAOX_WEBSOCKET_PORT=9002
# DRAOX_HTTP_PORT=9003
# DRAOX_ADMIN_API_PORT=9100
# DRAOX_METRICS_PORT=9090

# Optional: database URL override
# DRAOX_STORAGE_SQL_URL=sqlite:///var/lib/draox-server/draox.db?mode=rwc

# Optional: Redis URL override
# DRAOX_CACHE_REDIS_URL=redis://localhost:6379
