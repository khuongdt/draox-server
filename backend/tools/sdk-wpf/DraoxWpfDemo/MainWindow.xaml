<Window x:Class="DraoxWpfDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Draox Messaging Demo"
        Height="720" Width="1060"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

  <Window.Resources>
    <!-- Button base template with rounded corners -->
    <Style x:Key="Btn" TargetType="Button">
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="4" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource Btn}">
      <Setter Property="Background" Value="#89B4FA"/>
      <Setter Property="Foreground" Value="#1E1E2E"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource Btn}">
      <Setter Property="Background" Value="#45475A"/>
    </Style>

    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource Btn}">
      <Setter Property="Background" Value="#F38BA8"/>
      <Setter Property="Foreground" Value="#1E1E2E"/>
    </Style>

    <Style x:Key="Field" TargetType="TextBox">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="CaretBrush" Value="#CDD6F4"/>
      <Setter Property="BorderBrush" Value="#45475A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8,5"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="Label" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#6C7086"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Margin" Value="0,8,0,2"/>
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#89B4FA"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Margin" Value="0,14,0,4"/>
    </Style>

    <!-- ListViewItem: transparent, no hover highlight -->
    <Style TargetType="ListViewItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListViewItem">
            <ContentPresenter/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ── Sidebar ──────────────────────────────────────────────────────────── -->
    <Border Grid.Column="0" Background="#181825">
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,12">
        <StackPanel>

          <TextBlock Text="DRAOX DEMO" Foreground="#89B4FA"
                     FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>

          <!-- Status indicator -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#F38BA8"
                     VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="TxtStatus" Text="Disconnected"
                       Foreground="#A6ADC8" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock x:Name="TxtSession" Foreground="#6C7086" FontSize="11"
                     TextWrapping="Wrap" Margin="0,0,0,4"/>

          <!-- Connection -->
          <TextBlock Text="CONNECTION" Style="{StaticResource SectionTitle}"/>

          <TextBlock Text="Host" Style="{StaticResource Label}"/>
          <TextBox x:Name="TxtHost" Text="127.0.0.1" Style="{StaticResource Field}"/>

          <TextBlock Text="Port" Style="{StaticResource Label}"/>
          <TextBox x:Name="TxtPort" Text="9002" Style="{StaticResource Field}"/>

          <TextBlock Text="Protocol" Style="{StaticResource Label}"/>
          <ComboBox x:Name="CmbProtocol" SelectedIndex="0"
                    Background="#313244" Foreground="#CDD6F4"
                    BorderBrush="#45475A" Padding="8,5" FontSize="13">
            <ComboBoxItem Content="WebSocket"/>
            <ComboBoxItem Content="TCP"/>
          </ComboBox>

          <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <Button x:Name="BtnConnect" Content="Connect"
                    Style="{StaticResource BtnPrimary}"
                    Click="BtnConnect_Click" MinWidth="82"/>
            <Button x:Name="BtnDisconnect" Content="Disconnect"
                    Style="{StaticResource BtnDanger}"
                    Click="BtnDisconnect_Click"
                    IsEnabled="False" Margin="6,0,0,0" MinWidth="82"/>
          </StackPanel>

          <!-- Auth -->
          <TextBlock Text="AUTHENTICATION" Style="{StaticResource SectionTitle}"/>

          <TextBlock Text="Username" Style="{StaticResource Label}"/>
          <TextBox x:Name="TxtUsername" Text="admin" Style="{StaticResource Field}"/>

          <TextBlock Text="Password" Style="{StaticResource Label}"/>
          <PasswordBox x:Name="PwdPassword"
                       Background="#313244" Foreground="#CDD6F4"
                       CaretBrush="#CDD6F4" BorderBrush="#45475A"
                       BorderThickness="1" Padding="8,5" FontSize="13"/>

          <Button x:Name="BtnAuth" Content="Login"
                  Style="{StaticResource BtnPrimary}"
                  Click="BtnAuth_Click"
                  Margin="0,8,0,0" IsEnabled="False"/>

          <!-- Channel -->
          <TextBlock Text="CHANNEL" Style="{StaticResource SectionTitle}"/>

          <TextBlock Text="Channel ID" Style="{StaticResource Label}"/>
          <TextBox x:Name="TxtChannel" Text="general" Style="{StaticResource Field}"/>

          <Button x:Name="BtnHistory" Content="Load History"
                  Style="{StaticResource BtnSecondary}"
                  Click="BtnHistory_Click"
                  Margin="0,6,0,0" IsEnabled="False"/>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ── Chat Area ─────────────────────────────────────────────────────────── -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Channel header -->
      <Border Grid.Row="0" Background="#181825" BorderBrush="#313244"
              BorderThickness="0,0,0,1" Padding="16,10">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="# " Foreground="#89B4FA" FontSize="16" FontWeight="Bold"/>
          <TextBlock x:Name="TxtChannelHeader" Text="general"
                     Foreground="#CDD6F4" FontSize="16" FontWeight="SemiBold"/>
        </StackPanel>
      </Border>

      <!-- Message list -->
      <ListView x:Name="LvMessages" Grid.Row="1"
                Background="#1E1E2E"
                BorderBrush="Transparent"
                Padding="12,8"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                VirtualizingPanel.IsVirtualizing="True">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Border Padding="4,5" Margin="0,1">
              <StackPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding Sender}" Foreground="{Binding SenderColor}"
                             FontWeight="SemiBold" FontSize="13"/>
                  <TextBlock Text="{Binding Time}" Foreground="#6C7086"
                             FontSize="11" Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <TextBlock Text="{Binding Text}" Foreground="#CDD6F4"
                           FontSize="14" TextWrapping="Wrap" Margin="0,2,0,0"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <!-- Input area -->
      <Border Grid.Row="2" Background="#181825" BorderBrush="#313244"
              BorderThickness="0,1,0,0" Padding="12,10">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox x:Name="TxtInput" Grid.Column="0"
                   Style="{StaticResource Field}"
                   FontSize="14" IsEnabled="False"
                   KeyDown="TxtInput_KeyDown"/>
          <Button x:Name="BtnSend" Grid.Column="1" Content="Send"
                  Style="{StaticResource BtnPrimary}"
                  Click="BtnSend_Click"
                  Margin="8,0,0,0" Padding="20,6"
                  IsEnabled="False"/>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
