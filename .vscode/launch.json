        // ───────── Debug Current Test ─────────
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Current Test (cursor)",
            "cargo": {
                "args": [
                    "test",
                    "--manifest-path", "${workspaceFolder}/backend/Cargo.toml",
                    "--package=${command:currentPackage}",
                    "--no-run"
                ],
                "filter": { "kind": "lib" }
            },
            "args": ["${selectedText}"],
            "env": { "RUST_LOG": "debug", "RUST_BACKTRACE": "1" },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Debug Full Stack (Server + Frontend)",
            "configurations": ["Debug Draox Server", "Debug Frontend (Chrome)"],
            "stopAll": true
        }
    ]
}
