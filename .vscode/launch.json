{
    "version": "0.2.0",
    "configurations": [
        // ───────── Frontend ─────────
        {
            "type": "chrome",
            "request": "launch",
            "name": "Debug Frontend (Chrome)",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMapPathOverrides": {
                "webpack://?:*/*": "${workspaceFolder}/frontend/*",
                "webpack:///./~/*": "${workspaceFolder}/frontend/node_modules/*",
                "webpack:///*": "*"
            },
            "preLaunchTask": "frontend-dev"
        },
        {
            "type": "chrome",
            "request": "attach",
            "name": "Attach Frontend (Chrome)",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMapPathOverrides": {
                "webpack://?:*/*": "${workspaceFolder}/frontend/*",
                "webpack:///./~/*": "${workspaceFolder}/frontend/node_modules/*",
                "webpack:///*": "*"
            },
            "port": 9222
        },

        // ───────── Run / Debug Server ─────────
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Draox Server",
            "cargo": {
                "args": [
                    "build",
                    "--manifest-path", "${workspaceFolder}/backend/Cargo.toml",
                    "--bin=draox-server",
                    "--package=draox-server"
                ],
                "filter": {
                    "name": "draox-server",
                    "kind": "bin"
                }
            },
            "args": ["--config", "config/default.toml"],
            "env": {
                "RUST_LOG": "debug,draox_server=trace",
                "RUST_BACKTRACE": "1",
                "DRAOX_ADMIN_JWT_SECRET": "dev-secret-change-in-production"
            },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Run Draox Server (Release)",
            "cargo": {
                "args": [
                    "build",
                    "--manifest-path", "${workspaceFolder}/backend/Cargo.toml",
                    "--bin=draox-server",
                    "--package=draox-server",
                    "--release"
                ],
                "filter": {
                    "name": "draox-server",
                    "kind": "bin"
                }
            },
            "args": ["--config", "config/default.toml"],
            "env": {
                "RUST_LOG": "info",
                "DRAOX_ADMIN_JWT_SECRET": "dev-secret-change-in-production"
            },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },

        // ───────── Test Configurations ─────────
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug All Tests",
            "cargo": {
                "args": [
                    "test",
                    "--manifest-path", "${workspaceFolder}/backend/Cargo.toml",
                    "--workspace",
                    "--no-run"
                ],
                "filter": {
                    "kind": "test"
                }
            },
            "env": {
                "RUST_LOG": "debug",
                "RUST_BACKTRACE": "1"
            },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Tests — server-core",
            "cargo": {
                "args": ["test", "--manifest-path", "${workspaceFolder}/backend/Cargo.toml", "--package=server-core", "--no-run"],
                "filter": { "kind": "lib" }
            },
            "env": { "RUST_LOG": "debug", "RUST_BACKTRACE": "1" },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
